{
  "name": "rainy-cole-blog",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "db:generate": "pnpm --filter @rainy/api prisma:generate",
    "db:migrate": "pnpm --filter @rainy/api prisma:migrate",
    "db:seed": "pnpm --filter @rainy/api prisma:seed",
    "docker:up": "docker compose -f infra/docker/docker-compose.yml up -d --build",
    "docker:down": "docker compose -f infra/docker/docker-compose.yml down"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.1.1",
    "typescript": "^5.5.4"
  }
}
