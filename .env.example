NODE_ENV=development

WEB_PORT=5173
ADMIN_PORT=5174
API_PORT=3000
POSTGRES_PORT=5432
MEILI_PORT=7700
NGINX_PORT=8080

# 本机直接运行 API 时使用 localhost。
# Docker Compose 会自动改用容器内地址 postgres，不需要单独维护 .env.docker。
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rainy_cole?schema=public
POSTGRES_DB=rainy_cole
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh

MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=change-me-search

UPLOAD_DIR=./apps/api/uploads

# 生产服务器可覆盖为镜像仓库地址，例如 registry.example.com/rainy-cole-api:latest
API_IMAGE=rainy-cole-api:latest
NGINX_IMAGE=rainy-cole-nginx:latest
